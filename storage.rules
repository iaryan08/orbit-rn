rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: get the user's coupleId from Firestore
    function getCoupleId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.couple_id;
    }

    // Helper: check if user belongs to the couple corresponding to the path
    function belongsToCouple(coupleId) {
      return request.auth != null && getCoupleId() == coupleId;
    }

    match /couples/{coupleId}/{allPaths=**} {
      allow read, write: if belongsToCouple(coupleId);
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
