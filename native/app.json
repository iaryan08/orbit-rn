{
  "expo": {
    "name": "Orbit",
    "slug": "orbit-v2-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "scheme": "orbit",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aryan.orbitv2",
      "permissions": [
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Orbit to save memories to your gallery.",
          "savePhotosPermission": "Allow Orbit to save memories to your gallery.",
          "audioPermission": "Allow Orbit to access audio for memories.",
          "isStandard": true
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "react-native-compressor",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Orbit to access your location to share weather with your partner.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8dba604e-7f8f-4bf1-bd84-e70058ab1e45"
      }
    },
    "owner": "gitgryffindor08"
  }
}